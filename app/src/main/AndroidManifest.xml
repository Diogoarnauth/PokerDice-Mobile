<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ChelasMultiPlayerPokerDice">
        <activity
            android:name=".titleScreen.TitleScreenActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ChelasMultiPlayerPokerDice">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".aboutScreen.AboutScreenActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ChelasMultiPlayerPokerDice"/>
        <activity
            android:name=".playerProfileScreen.PlayerProfileActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ChelasMultiPlayerPokerDice"/>
        <activity
            android:name=".lobbyCreationScreen.LobbyCreationActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ChelasMultiPlayerPokerDice"/>
        <activity
            android:name=".lobbyScreen.LobbyScreenActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ChelasMultiPlayerPokerDice"/>
        <activity
            android:name=".lobbies.LobbiesActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ChelasMultiPlayerPokerDice"/>
    </application>

</manifest>